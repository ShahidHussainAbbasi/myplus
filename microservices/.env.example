# MyPlus microservices — secret template. COPY to `.env.local` (git-ignored) and fill in real
# values for local dev; in prod inject these from AWS Secrets Manager / SSM (never commit real values).
# Loaded by start-all.ps1 (exported to each service JVM) and auto-read by docker-compose.
# Service application.yml files reference these as ${VAR}; unset → the dev placeholder in yml.

# --- Database (per-service MySQL) ---
DB_USER=root
DB_PASSWORD=changeme

# --- JWT signing key (auth-service + api-gateway MUST share the same value) ---
# Generate a strong key, e.g. base64 of 48 random bytes:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-strong-random-256bit-key

# --- Internal trust secret (gateway stamps it; services trust X-User-* only when it matches) ---
# Leave empty for local dev (enforcement off); set a strong shared value in prod.
INTERNAL_SECRET=

# --- Mail (auth-service + education-service verification / alert emails) ---
# Gmail requires an app-specific password. Empty in dev = mail simply not sent.
MAIL_PASSWORD=

# --- Prod-only (set in the deployment env, not needed for local dev) ---
# CORS_ALLOWED_ORIGINS=https://app.example.com
# DDL_AUTO=validate            # 'update' on first prod boot, 'validate' once Flyway baselines exist
# RECAPTCHA_SECRET=
