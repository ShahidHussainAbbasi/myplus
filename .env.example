# Monolith (myplus) local secrets template. COPY to `.env.local` (git-ignored) and fill real
# values for dev; in prod inject from the environment / AWS Secrets Manager. Loaded by
# application.properties via `spring.config.import=optional:file:./.env.local[.properties]`.

# Database (myplusdb)
DB_USER=root
DB_PASSWORD=changeme

# Mail (Gmail app-specific password). Empty = mail not sent in dev.
MAIL_PASSWORD=

# Google reCAPTCHA secret. Empty = captcha disabled in dev.
RECAPTCHA_SECRET=

# Internal infra basic-auth (defaults are fine for local dev)
# CONFIG_SERVER_PASSWORD=config-pass
# EUREKA_PASSWORD=eureka-pass
