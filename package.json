{
  "name": "myplus",
  "version": "1.0.0",
  "description": "Cypress E2E tests for myplus Spring Boot application",
  "scripts": {
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:business": "cypress run --spec 'cypress/e2e/business/**/*.cy.js'",
    "test:e2e:auth": "cypress run --spec 'cypress/e2e/auth/**/*.cy.js'",
    "test:e2e:pages": "cypress run --spec 'cypress/e2e/pages/**/*.cy.js'",
    "test:e2e:education:demo": "cypress run --browser chrome --headed --config video=true --spec cypress/e2e/education/demo.cy.js"
  },
  "devDependencies": {
    "cypress": "^13.13.0"
  }
}
